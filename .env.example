# Email sending (recommended)
RESEND_API_KEY=your_resend_api_key
# Must be a verified sender in Resend (e.g. "Afendi Property <noreply@yourdomain.com>")
RESEND_FROM=Afendi Property <noreply@yourdomain.com>

# Where notifications go
ENQUIRIES_TO=enquiries@afendiproperty.com

# Public site URL (used in metadata)
NEXT_PUBLIC_SITE_URL=https://afendiproperty.com
